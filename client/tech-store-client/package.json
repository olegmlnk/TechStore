    "test:unit:broken": "ng test --watch=false --configuration broken",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "serve:ssr:tech-store-client": "node dist/tech-store-client/server/server.mjs",
    "lint": "ng lint"
  },
  "private": true,
  "packageManager": "npm@10.9.4",
  "dependencies": {
    "@angular/common": "^21.1.0",
