  "scripts": {
    "ng": "ng",
    "dev": "ng serve",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "preview": "node dist/tech-store-client/server/server.mjs",
    "test": "ng test",
